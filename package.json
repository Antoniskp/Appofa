{
  "name": "appofa",
  "version": "1.0.0",
  "description": "Application for news, education and polls",
  "main": "src/index.js",
  "scripts": {
    "lint": "eslint src app components hooks lib && node scripts/check-migrations.js",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "frontend": "next dev -p 3001",
    "frontend:build": "next build",
    "frontend:start": "node scripts/start-frontend.js",
    "deploy:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-and-deploy.ps1",
    "deploy:publish:pr": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-and-deploy.ps1 -CreatePr",
    "deploy:publish:merge": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-and-deploy.ps1 -CreatePr -MergePr",
    "seed": "node src/scripts/populate-db.js",
    "seed:locations": "node src/scripts/seed-locations.js",
    "seed:government-positions": "node src/scripts/seed-government-positions.js",
    "seed:government-current-holders": "node src/scripts/seed-government-current-holders.js",
    "migrate": "node src/scripts/run-migrations.js",
    "migrate:up": "node src/scripts/run-migrations.js up",
    "migrate:down": "node src/scripts/run-migrations.js down",
    "migrate:status": "node src/scripts/run-migrations.js status",
    "migrate:article-types": "node src/scripts/update-article-types.js"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "autoprefixer": "^10.4.24",
    "axios": "1.16.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "geoip-lite": "^2.0.1",
    "heic2any": "^0.0.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "multer": "^2.1.1",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "postcss": "^8.5.10",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sequelize": "^6.37.8",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.19",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  },
  "overrides": {
    "@swc/helpers": "0.5.21",
    "tar": ">=7.5.11",
    "flatted": ">=3.4.2",
    "glob": "^13.0.0",
    "rimraf": "^6.0.1",
    "underscore": ">=1.13.8",
    "@tootallnate/once": ">=3.0.1",
    "brace-expansion": ">=2.1.0 <3.0.0 || >=5.0.6",
    "lodash": ">=4.18.1",
    "uuid": ">=14.0.0",
    "esbuild": "0.25.3",
    "micromatch": "4.0.8",
    "ip-address": ">=10.1.1",
    "next": {
      "postcss": ">=8.5.10"
    },
    "next-intl": {
      "postcss": ">=8.5.10"
    },
    "undici": ">=6.27.0",
    "js-yaml": ">=4.2.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.10",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.11",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  }
}
